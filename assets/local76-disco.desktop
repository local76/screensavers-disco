[Desktop Entry]
Type=Application
Name=Disco
Comment=Screensaver effect: disco
Exec=env XCURSOR_PATH=/nonexistent XCURSOR_THEME=none xterm -fullscreen -bg black -fg white -ms black -xrm "XTerm*pointerColorBackground: black" -xrm "XTerm*pointerMode: 2" -e /usr/libexec/local76/screensavers/disco
Icon=local76-disco
Terminal=false
Categories=Screensaver;
